# Puma Benchmark Configuration
# ==============================
# Configuration file for evaluation parameters
# Copy this file to .env and modify values as needed
# These values can be overridden via environment variables

# ============================================
# GPU CONFIGURATION
# ============================================

# Enable GPU acceleration (default: true - GPU preferred with CPU fallback)
# Options:
#   - true: GPU acceleration if available, fallback to CPU (default, recommended)
#   - false: CPU only mode (force CPU, most compatible)
#   - auto: Auto-detect GPU availability (uses start_puma.sh)
GPU_MODE=true

# Number of parallel requests to Ollama
# CPU mode: 1 (recommended for stability)
# GPU mode: 2-4 (depending on GPU VRAM)
OLLAMA_NUM_PARALLEL=1


# ============================================
# MODEL CONFIGURATION
# ============================================

# LLM Model to use (default: qwen2.5:3b)
# Recommended values:
#   - qwen2.5:0.5b  (0.6 GB RAM - very fast, lower accuracy)
#   - qwen2.5:1.8b  (1.9 GB RAM - fast, good balance)
#   - qwen2.5:3b    (3.9 GB RAM - recommended for 8GB RAM)
#   - qwen2.5:7b    (7.4 GB RAM - needs 16GB RAM)
#   - llama3:8b     (4.9 GB RAM - needs 16GB RAM)
#   - mistral:7b    (4.1 GB RAM - good for 16GB RAM)
LLM_MODEL=qwen2.5:3b

# Ollama host URL
# Use http://ollama:11434 for Docker container
# Use http://localhost:11434 for local testing
OLLAMA_HOST=http://ollama:11434


# ============================================
# TRIAGE EVALUATION CONFIGURATION
# ============================================

# Target F1-macro score for triage (default: 0.55)
# Recommended: 0.55 (original requirement)
# Minimum acceptable: 0.50
TRIAGE_TARGET_F1=0.55

# Number of issues for triage evaluation (default: 200)
# The dataset has 50 issues per class (200 total)
TRIAGE_NUM_ISSUES=200

# Temperature for triage LLM responses (default: 0.0)
# Recommended: 0.0 (deterministic)
# Higher values (0.1-0.3) add randomness
TRIAGE_TEMPERATURE=0.0

# Seed for reproducible triage results (default: 42)
TRIAGE_SEED=42

# Number of tokens to predict for triage (default: 10)
TRIAGE_NUM_PREDICT=10


# ============================================
# ESTIMATION EVALUATION CONFIGURATION
# ============================================

# Target MAE (Mean Absolute Error) for estimation (default: 3.0)
# Recommended: 3.0 (original requirement)
# Lower is better - Fibonacci series is 1,2,3,5,8,13,21
ESTIMATION_TARGET_MAE=3.0

# Project to evaluate for estimation (default: MESOS)
# Available options: MESOS, APSTUD, XD
# Recommended for quick tests: APSTUD (476 items)
# Recommended for full benchmark: MESOS (1513 items)
ESTIMATION_PROJECT=MESOS

# Maximum number of items to evaluate (default: 0 = all items)
# Use this to limit evaluation time for testing:
#   - 0: All items (default)
#   - 50: Quick test (~10-15 min with GPU, ~1 hour with CPU)
#   - 100: Short test (~20-30 min with GPU, ~2 hours with CPU)
#   - 200: Medium test (~1 hour with GPU, ~4 hours with CPU)
#   - 476: APSTUD full dataset
#   - 811: XD full dataset
#   - 1513: MESOS full dataset
ESTIMATION_NUM_ITEMS=0

# Temperature for estimation LLM responses (default: 0.0)
# Recommended: 0.0 (deterministic)
ESTIMATION_TEMPERATURE=0.0

# Seed for reproducible estimation results (default: 42)
ESTIMATION_SEED=42

# Number of tokens to predict for estimation (default: 50)
ESTIMATION_NUM_PREDICT=50


# ============================================
# TIMEOUT CONFIGURATION
# ============================================

# Evaluation timeout in seconds (default: 3600 = 1 hour)
# Set to 0 for no timeout
# Examples:
#   - 3600: 1 hour
#   - 7200: 2 hours
#   - 14400: 4 hours
#   - 28800: 8 hours
#   - 0: No timeout (run until complete)
EVALUATION_TIMEOUT=0


# ============================================
# DATA CONFIGURATION
# ============================================

# Path to Jira triage data (default: data/jira_balanced_200.csv)
DATA_JIRA_FILE=data/jira_balanced_200.csv

# Path to TAWOS estimation data (default: data/tawos_clean.csv)
DATA_TAWOS_FILE=data/tawos_clean.csv


# ============================================
# CACHE CONFIGURATION
# ============================================

# Enable/disable caching (default: 1)
# Set to 0 to always re-run evaluations without cache
USE_CACHE=1

# Path to triage cache (default: results/triage_cache.json)
CACHE_TRIAGE_FILE=results/triage_cache.json

# Path to estimation cache (default: results/estimation_cache.json)
CACHE_ESTIMATION_FILE=results/estimation_cache.json


# ============================================
# RESULTS CONFIGURATION
# ============================================

# Path to results directory (default: results)
RESULTS_DIR=results

# Path to reports directory (default: reports)
REPORTS_DIR=reports


# ============================================
# SYSTEM CONFIGURATION
# ============================================

# Python output buffer (default: 1)
PYTHONUNBUFFERED=1

# Log level (default: INFO)
# Options: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# PUMA
WHITE_PUMA_MODE=0
